// chatgpt refactored schema
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum ActivityStatus {
  ACTIVE
  INACTIVE
  CANCELLED
  DELAYED
}

enum ProfileRole {
  MEMBER
  LEADER
  BOARD_MEMBER
  ADMIN
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model Profile {
  id          String      @id @default(uuid())
  email       String      @unique @db.VarChar(255)
  password    String      @db.Text
  profileName String?     @db.VarChar(255)
  role        ProfileRole @default(MEMBER)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  leaderActivities LeaderActivity[]
  favorites        Favorite[]
  participations   ParticipationLog[]

  @@index([email])
}

// ──────────────────────────────────────────────

model ActivityTemplate {
  id            String         @id @default(uuid())
  name          String         @db.VarChar(255)
  description   String?        @db.VarChar(500)
  location      String         @db.VarChar(255)
  maxCapacity   Int?
  defaultStatus ActivityStatus @default(ACTIVE)
  notes         String?        @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leaders   LeaderActivity[]
  favorites Favorite[]
  schedules Schedule[]
  timeSlots TimeSlot[]

  @@index([name])
}

// ──────────────────────────────────────────────

model Schedule {
  id         String         @id @default(uuid())
  activityId String
  startAt    DateTime
  endAt      DateTime?
  status     ActivityStatus
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  activity ActivityTemplate @relation(fields: [activityId], references: [id], onDelete: Cascade)

  participations ParticipationLog[]

  @@index([activityId])
  @@index([startAt])
}

// ──────────────────────────────────────────────
// ──────────────────────────────────────────────
//   HELPER TABLES (RELATIONSHIPS OR DATA)
// ──────────────────────────────────────────────
// ──────────────────────────────────────────────

// ──────────────────────────────────────────────
// Normalized time slots (replaces JSON)
// ──────────────────────────────────────────────

model TimeSlot {
  id         String   @id @default(uuid())
  activityId String
  weekday    Weekday
  startTime  DateTime @db.Time(6)
  endTime    DateTime @db.Time(6)

  activity ActivityTemplate @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([activityId, weekday, startTime]) // prevents double booking of time-slot
  @@index([activityId, weekday])
}

// ──────────────────────────────────────────────
// Many-to-many relationships (profile ↔ ActivityTemplate)
// ──────────────────────────────────────────────

model LeaderActivity {
  profileId  String
  activityId String

  profile  Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  activity ActivityTemplate @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([profileId, activityId])
}

// ──────────────────────────────────────────────

model Favorite {
  profileId  String
  activityId String

  profile  Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  activity ActivityTemplate @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@id([profileId, activityId])
}

// ──────────────────────────────────────────────
// Participation (profile ↔ schedule)
// ──────────────────────────────────────────────

model ParticipationLog {
  id         String  @id @default(uuid())
  profileId  String
  scheduleId String
  interested Boolean @default(false)

  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([profileId, scheduleId])
  @@index([scheduleId])
}
